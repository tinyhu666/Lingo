{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lingo",
  "version": "0.9.5",
  "identifier": "io.github.tinyhu666.lingo",
  "build": {
    "beforeDevCommand": "npm run dev:desktop",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Lingo",
        "width": 1280,
        "height": 720,
        "minWidth": 1280,
        "maxWidth": 1280,
        "minHeight": 720,
        "maxHeight": 720,
        "theme": "Light",
        "visible": true,
        "decorations": false,
        "transparent": true,
        "shadow": false
      },
      {
        "label": "incoming-overlay",
        "title": "Lingo Incoming",
        "url": "overlay.html",
        "width": 360,
        "height": 600,
        "minWidth": 280,
        "minHeight": 200,
        "maxWidth": 480,
        "maxHeight": 900,
        "x": 1540,
        "y": 60,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "resizable": true,
        "visible": false,
        "acceptFirstMouse": true
      },
      {
        "label": "region-picker",
        "title": "Lingo Region Picker",
        "url": "region-picker.html",
        "width": 1280,
        "height": 720,
        "x": 0,
        "y": 0,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true,
        "resizable": false,
        "visible": false,
        "acceptFirstMouse": true
      }
    ]
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg",
      "msi",
      "nsis"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "signingIdentity": "-",
      "dmg": {
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        },
        "windowSize": {
          "height": 400,
          "width": 660
        }
      },
      "files": {},
      "hardenedRuntime": false,
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "https://timestamp.digicert.com",
      "signCommand": "powershell -ExecutionPolicy Bypass -File ./scripts/sign-windows.ps1 %1",
      "wix": {
        "version": "0.9.5.0",
        "language": [
          "zh-CN"
        ]
      }
    },
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2QjIxRjIyM0NCRDIxRDUKUldUVkliMDhJaCt5VnVrcHFSSDBxL09TUUFONStzeWF2R1dZMVlQam8yUWFzL0IxT0drNXNjWm4K",
      "endpoints": [
        "https://lingo-1259551686.cos.ap-shanghai.myqcloud.com/releases/latest.json",
        "https://github.com/tinyhu666/Lingo/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
