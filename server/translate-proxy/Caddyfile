{$CADDY_DOMAIN:translate.example.com} {
  encode zstd gzip

  @api path /healthz /translate /analytics* /admin* /public/site-config /public/client-config /vision*
  handle @api {
    reverse_proxy translate-proxy:8787
  }

  handle {
    root * /srv/lingoweb
    try_files {path} {path}/ /index.html
    file_server
  }
}
