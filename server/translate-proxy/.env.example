PORT=8787
ADMIN_TOKEN=replace-with-a-long-random-token
BACKEND_PUBLIC_KEY=replace-with-a-public-client-key
CADDY_DOMAIN=buffpp.com,lingo.ink
MODEL_PROVIDER=openai-compatible
MODEL_API_URL=https://api.siliconflow.cn/v1/chat/completions
MODEL_NAME=deepseek-ai/DeepSeek-V3.2
MODEL_API_KEY=replace-with-your-model-api-key
MODEL_API_KEY_ENV_NAME=MODEL_API_KEY
MODEL_TIMEOUT_MS=12000
MODEL_MAX_TOKENS=96
MODEL_TEMPERATURE=0.2
MODEL_ENABLED=true
RUNTIME_CONFIG_PATH=/app/data/runtime-config.json
ANALYTICS_DB_PATH=/app/data/analytics.sqlite
