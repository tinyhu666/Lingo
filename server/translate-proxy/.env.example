PORT=8787
ADMIN_TOKEN=replace-with-a-long-random-token
BACKEND_PUBLIC_KEY=replace-with-a-public-client-key
MODEL_PROVIDER=openai-compatible
MODEL_API_URL=https://api.siliconflow.cn/v1/chat/completions
